---
import { services } from '../data/company';
const categories = [
  { slug: 'data-governance', name: 'Data Governance', icon: 'fa-sitemap' },
  { slug: 'data-quality', name: 'Data Quality', icon: 'fa-chart-line' },
  { slug: 'compliance', name: 'Compliance', icon: 'fa-scale-balanced' },
];
---

<div class="urgency-bar">
  <div class="container urgency-bar__inner">
    <i class="fa-solid fa-clock"></i>
    <span>Plazo Ley 31814: <strong class="countdown-inline"></strong></span>
    <a href="/cumplimiento-ley-31814/plazos-cumplimiento/" class="urgency-bar__link">Ver plazos →</a>
  </div>
</div>
<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="AI Governance Perú - Inicio">
      <img src="/images/logo.svg" alt="AI Governance Perú" width="180" height="45" loading="eager" />
    </a>

    <button class="header__toggle" data-menu-toggle aria-label="Abrir menú" aria-expanded="false">
      <i class="fa-solid fa-bars"></i>
    </button>

    <nav class="nav" data-nav aria-label="Navegación principal">
      <div class="nav__item" data-dropdown>
        <button class="nav__link" data-dropdown-toggle aria-expanded="false">
          Servicios <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="nav__dropdown">
          {categories.map((cat) => (
            <div class="nav__dropdown-group">
              <a href={`/servicios/#${cat.slug}`} class="nav__dropdown-heading">
                <i class={`fa-solid ${cat.icon}`}></i> {cat.name}
              </a>
              {services.filter((s) => s.category === cat.slug).map((s) => (
                <a href={`/servicios/${s.slug}/`} class="nav__dropdown-link">
                  {s.shortTitle}
                </a>
              ))}
            </div>
          ))}
        </div>
      </div>

      <div class="nav__item" data-dropdown>
        <button class="nav__link" data-dropdown-toggle aria-expanded="false">
          Ley 31814 <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="nav__dropdown nav__dropdown--compact">
          <a href="/cumplimiento-ley-31814/" class="nav__dropdown-link">Guía Completa</a>
          <a href="/cumplimiento-ley-31814/que-es-ley-31814/" class="nav__dropdown-link">¿Qué es la Ley 31814?</a>
          <a href="/cumplimiento-ley-31814/ds-115-2025-pcm/" class="nav__dropdown-link">DS 115-2025-PCM</a>
          <a href="/cumplimiento-ley-31814/plazos-cumplimiento/" class="nav__dropdown-link">Plazos de Cumplimiento</a>
          <a href="/cumplimiento-ley-31814/requisitos-sector-financiero/" class="nav__dropdown-link">Requisitos por Sector</a>
        </div>
      </div>

      <div class="nav__item" data-dropdown>
        <button class="nav__link" data-dropdown-toggle aria-expanded="false">
          Áreas <i class="fa-solid fa-chevron-down"></i>
        </button>
        <div class="nav__dropdown nav__dropdown--compact">
          <a href="/areas/peru/" class="nav__dropdown-link">Perú</a>
          <a href="/areas/lima/" class="nav__dropdown-link">Lima</a>
        </div>
      </div>

      <a href="/nosotros/" class="nav__link">Nosotros</a>
      <a href="/recursos/" class="nav__link">Recursos</a>
      <a href="/contacto/" class="nav__link btn btn--primary btn--sm nav__cta">Contacto</a>
    </nav>
  </div>
</header>

<style>
  .urgency-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 101;
    background: linear-gradient(90deg, #1e3a5f, #ef4444);
    color: #fff; font-size: 0.8rem; height: 32px;
    display: flex; align-items: center;
  }
  .urgency-bar__inner {
    display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  }
  .urgency-bar__link {
    color: rgba(255,255,255,0.9); text-decoration: underline; margin-left: 0.5rem; font-size: 0.75rem;
  }
  .urgency-bar__link:hover { color: #fff; }
  .header {
    position: fixed; top: 32px; left: 0; right: 0; z-index: 100;
    background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);
    border-bottom: 1px solid transparent;
    transition: all 150ms ease;
    height: var(--header-height);
  }
  .header--scrolled { border-bottom-color: var(--color-border); box-shadow: var(--shadow-sm); }
  .header__inner { display: flex; align-items: center; justify-content: space-between; height: 100%; }
  .header__logo img { height: 36px; width: auto; }
  .header__toggle { display: none; background: none; border: none; font-size: 1.25rem; cursor: pointer; padding: 0.5rem; color: var(--color-text); }
  .nav { display: flex; align-items: center; gap: 0.25rem; }
  .nav__item { position: relative; }
  .nav__link {
    display: flex; align-items: center; gap: 0.375rem;
    padding: 0.5rem 0.75rem; font-size: 0.9rem; font-weight: 500;
    color: var(--color-text); background: none; border: none; cursor: pointer;
    border-radius: var(--radius-md); transition: all 150ms;
    text-decoration: none; white-space: nowrap;
  }
  .nav__link:hover { color: var(--color-accent); background: var(--color-bg-alt); }
  .nav__link i { font-size: 0.65rem; transition: transform 150ms; }
  .nav__dropdown {
    display: none; position: absolute; top: 100%; left: 0;
    background: #fff; border: 1px solid var(--color-border);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-lg);
    padding: 1rem; min-width: 560px; z-index: 50;
    grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .nav__dropdown--compact { min-width: 240px; display: none; flex-direction: column; gap: 0.25rem; }
  .dropdown--open > .nav__dropdown { display: grid; }
  .dropdown--open > .nav__dropdown--compact { display: flex; }
  .dropdown--open > .nav__link i { transform: rotate(180deg); }
  .nav__dropdown-group { display: flex; flex-direction: column; gap: 0.25rem; }
  .nav__dropdown-heading {
    display: flex; align-items: center; gap: 0.5rem;
    font-weight: 600; font-size: 0.85rem; color: var(--color-primary-dark);
    padding: 0.5rem; margin-bottom: 0.25rem; text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .nav__dropdown-heading:hover { background: var(--color-bg-alt); color: var(--color-accent); }
  .nav__dropdown-heading i { color: var(--color-accent); }
  .nav__dropdown-link {
    display: block; padding: 0.375rem 0.5rem; font-size: 0.85rem;
    color: var(--color-text-light); border-radius: var(--radius-sm);
    transition: all 150ms; text-decoration: none;
  }
  .nav__dropdown-link:hover { background: var(--color-bg-alt); color: var(--color-accent); }
  .nav__cta { margin-left: 0.5rem; }

  @media (max-width: 1024px) {
    .header__toggle { display: block; }
    .nav {
      display: none; position: fixed; top: calc(var(--header-height) + 32px); left: 0; right: 0; bottom: 0;
      flex-direction: column; background: #fff; padding: 1.5rem; gap: 0.5rem;
      overflow-y: auto; align-items: stretch;
    }
    .nav--open { display: flex; }
    .nav__dropdown { position: static; box-shadow: none; border: none; min-width: 0; padding: 0 0 0 1rem; grid-template-columns: 1fr; }
    .nav__dropdown--compact { min-width: 0; padding: 0 0 0 1rem; }
    .nav__cta { margin-left: 0; margin-top: 1rem; justify-content: center; }
  }
</style>
